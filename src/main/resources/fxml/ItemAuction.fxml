<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ItemAuctionController">
   <children>
      <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#e79316" height="59.0" stroke="BLACK" strokeType="INSIDE" width="600.0" />
      <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#e79316" height="88.0" layoutX="310.0" layoutY="289.0" stroke="BLACK" strokeType="INSIDE" width="272.0" />
      <Button fx:id="outButton" layoutX="504.0" layoutY="14.0" mnemonicParsing="false" onAction="#OutAuction" prefHeight="31.0" prefWidth="65.0" style="-fx-background-color: white;" text="Back" textFill="#e79316">
         <font>
            <Font name="Trebuchet MS" size="16.0" />
         </font></Button>
      <Label fx:id="titleLabel" layoutX="14.0" layoutY="6.0" prefHeight="54.0" prefWidth="346.0" text="ItemName" textFill="WHITE">
         <font>
            <Font name="Trebuchet MS" size="37.0" />
         </font></Label>
      <Label fx:id="descLabel" alignment="TOP_LEFT" layoutX="22.0" layoutY="107.0" prefHeight="115.0" prefWidth="246.0" text="Description: ">
         <font>
            <Font name="Trebuchet MS" size="14.0" />
         </font></Label>
      <Label fx:id="miscLabel" alignment="TOP_LEFT" layoutX="22.0" layoutY="243.0" prefHeight="74.0" prefWidth="233.0" text="Misc: ">
         <font>
            <Font name="Trebuchet MS" size="14.0" />
         </font></Label>
      <VBox alignment="CENTER_RIGHT" layoutX="314.0" layoutY="107.0" spacing="2.0">
         <children>
            <Label alignment="CENTER_RIGHT" prefHeight="18.0" prefWidth="91.0" text="CURRENT PRICE" textFill="#e79316">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label fx:id="currentPriceLabel" alignment="TOP_RIGHT" prefHeight="31.0" prefWidth="246.0" text="\$[CurrentPrice]">
               <font>
                  <Font name="Trebuchet MS" size="25.0" />
               </font>
            </Label>
            <Label alignment="CENTER_RIGHT" prefHeight="18.0" prefWidth="142.0" text="HIGHEST BIDDER" textFill="#e79316">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label fx:id="highestBidderLabel" alignment="TOP_RIGHT" text="[OnlyTwentyCharacters]">
               <font>
                  <Font name="Trebuchet MS" size="25.0" />
               </font>
            </Label>
            <Label alignment="CENTER_RIGHT" prefHeight="18.0" prefWidth="142.0" text="END DATE" textFill="#e79316">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label fx:id="endDateLabel" alignment="TOP_RIGHT" prefHeight="30.0" prefWidth="246.0" text="[EndDate]">
               <font>
                  <Font name="Trebuchet MS" size="25.0" />
               </font>
            </Label>
         </children>
      </VBox>
      <HBox layoutX="349.0" layoutY="333.0" spacing="10.0">
         <children>
            <TextField fx:id="bidTextField" />
            <Button fx:id="bidButton" mnemonicParsing="false" onAction="#onBidButtonPressed" text="Bid">
               <font>
                  <Font name="Trebuchet MS" size="15.0" />
               </font>
            </Button>
         </children>
      </HBox>
      <Label layoutX="349.0" layoutY="307.0" prefHeight="19.0" prefWidth="78.0" text="Bid Value" textFill="WHITE">
         <font>
            <Font name="Trebuchet MS" size="15.0" />
         </font></Label>
      <Label fx:id="notificationText" alignment="CENTER" layoutX="3.0" layoutY="70.0" prefHeight="20.0" prefWidth="594.0" text="Announcement Text" textFill="RED">
         <font>
            <Font name="Trebuchet MS Bold" size="16.0" />
         </font></Label>
   </children>
</AnchorPane>

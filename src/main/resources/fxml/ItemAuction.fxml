<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ItemAuctionController">
   <children>
      <Button fx:id="outButton" layoutX="69.0" layoutY="277.0" mnemonicParsing="false" onAction="#OutAuction" text="Back" />
      <Label fx:id="titleLabel" layoutX="73.0" layoutY="39.0" text="Title" />
      <Label fx:id="descLabel" layoutX="73.0" layoutY="65.0" text="Description: " />
      <Label fx:id="miscLabel" layoutX="74.0" layoutY="162.0" text="Misc: " />
      <Label fx:id="currentPriceLabel" layoutX="310.0" layoutY="33.0" text="CURRENT PRICE: ">
         <font>
            <Font size="21.0" />
         </font>
      </Label>
      <Label fx:id="endDateLabel" layoutX="310.0" layoutY="89.0" text="End Date: ">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Button fx:id="bidButton" layoutX="494.0" layoutY="277.0" mnemonicParsing="false" onAction="#onBidButtonPressed" text="Bid" />
      <TextField fx:id="bidTextField" layoutX="336.0" layoutY="277.0" />
      <Label layoutX="337.0" layoutY="252.0" text="BID VALUE" />
      <Label fx:id="highestBidderLabel" layoutX="310.0" layoutY="130.0" text="Highest Bidder:">
         <font>
            <Font size="13.0" />
         </font>
      </Label>
      <Label fx:id="notificationText" layoutX="337.0" layoutY="313.0" text="helo worl" />
   </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionItemMenuController">
   <children>
      <Label layoutX="87.0" layoutY="34.0" prefHeight="51.0" prefWidth="334.0" text="TẠO SẢN PHẨM">
         <font>
            <Font size="35.0" />
         </font>
      </Label>
      <Label layoutX="41.0" layoutY="94.0" prefHeight="51.0" prefWidth="167.0" text="Chọn 1 loại sp">
         <font>
            <Font size="23.0" />
         </font>
      </Label>
      <RadioButton fx:id="electronicsButton" layoutX="44.0" layoutY="171.0" mnemonicParsing="false" onAction="#onItemSelected" text="Electronics">
         <toggleGroup>
            <ToggleGroup fx:id="itemType" />
         </toggleGroup>
      </RadioButton>
      <RadioButton fx:id="artButton" layoutX="44.0" layoutY="200.0" mnemonicParsing="false" onAction="#onItemSelected" text="Art" toggleGroup="$itemType" />
      <RadioButton fx:id="vehicleButton" layoutX="44.0" layoutY="229.0" mnemonicParsing="false" onAction="#onItemSelected" text="Vehicle" toggleGroup="$itemType" />
      <RadioButton fx:id="otherButton" layoutX="44.0" layoutY="257.0" mnemonicParsing="false" onAction="#onItemSelected" selected="true" text="Other" toggleGroup="$itemType" />
      <Button fx:id="auctionButton" layoutX="48.0" layoutY="349.0" mnemonicParsing="false" onAction="#createAuction" text="AUCTION ITEM" />
      <AnchorPane fx:id="artPane" layoutX="266.0" layoutY="108.0" prefHeight="254.0" prefWidth="276.0" visible="false">
         <children>
            <TextField fx:id="authorTF" layoutX="25.0" layoutY="110.0" promptText="Author" />
            <TextField fx:id="genreTF" layoutX="25.0" layoutY="139.0" promptText="Genre" />
         </children>
      </AnchorPane>
      <AnchorPane fx:id="vehiclePane" layoutX="266.0" layoutY="108.0" prefHeight="254.0" prefWidth="276.0" visible="false">
         <children>
            <TextField fx:id="vehicleBrandTF" layoutX="25.0" layoutY="110.0" promptText="Brand" />
            <TextField fx:id="vinTF" layoutX="25.0" layoutY="139.0" prefHeight="26.0" prefWidth="204.0" promptText="Vehicle Identification Number (VIN)" />
            <TextField fx:id="mileageTF" layoutX="25.0" layoutY="172.0" promptText="Mileage" />
         </children>
      </AnchorPane>
      <AnchorPane fx:id="electronicsPane" layoutX="266.0" layoutY="108.0" prefHeight="254.0" prefWidth="276.0" visible="false">
         <children>
            <TextField fx:id="electronicsBrandTF" layoutX="15.0" layoutY="77.0" promptText="Brand" />
            <TextField fx:id="warrantyTF" layoutX="15.0" layoutY="114.0" promptText="Warranty" />
         </children>
      </AnchorPane>
      <TextField fx:id="startingPriceTF" layoutX="47.0" layoutY="290.0" promptText="Starting Price" />
      <TextField fx:id="descriptionTF" layoutX="47.0" layoutY="322.0" promptText="Description" />
      <Label fx:id="itemTypeLabel" layoutX="281.0" layoutY="94.0" prefHeight="51.0" prefWidth="246.0" text="ITEM_NAME">
         <font>
            <Font size="32.0" />
         </font>
      </Label>
      <Button fx:id="backButton" layoutX="7.0" layoutY="8.0" mnemonicParsing="false" onAction="#back" text="Back" />
   </children>
</AnchorPane>

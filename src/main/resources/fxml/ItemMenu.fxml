<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionItemMenuController">
   <children>
      <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#e79316" height="61.0" layoutX="-4.0" stroke="BLACK" strokeType="INSIDE" width="606.0" />
      <Label layoutX="20.0" layoutY="5.0" prefHeight="51.0" prefWidth="334.0" text="CREATE AUCTION" textFill="WHITE">
         <font>
            <Font name="Trebuchet MS" size="40.0" />
         </font>
      </Label>
      <VBox layoutX="249.0" layoutY="95.0" spacing="10.0">
         <children>
            <Label prefHeight="26.0" prefWidth="38.0" text="Type">
               <font>
                  <Font name="Trebuchet MS" size="15.0" />
               </font>
            </Label>
            <RadioButton fx:id="electronicsButton" mnemonicParsing="false" onAction="#onItemSelected" text="Electronics">
               <toggleGroup>
                  <ToggleGroup fx:id="itemType" />
               </toggleGroup>
               <font>
                  <Font name="Trebuchet MS" size="12.0" />
               </font>
            </RadioButton>
            <RadioButton fx:id="artButton" mnemonicParsing="false" onAction="#onItemSelected" text="Art" toggleGroup="$itemType">
               <font>
                  <Font name="Trebuchet MS" size="12.0" />
               </font>
            </RadioButton>
            <RadioButton fx:id="vehicleButton" mnemonicParsing="false" onAction="#onItemSelected" text="Vehicle" toggleGroup="$itemType">
               <font>
                  <Font name="Trebuchet MS" size="12.0" />
               </font>
            </RadioButton>
            <RadioButton fx:id="otherButton" mnemonicParsing="false" onAction="#onItemSelected" text="Other" toggleGroup="$itemType">
               <font>
                  <Font name="Trebuchet MS" size="12.0" />
               </font>
            </RadioButton>
         </children>
      </VBox>
      <Button fx:id="auctionButton" layoutX="214.0" layoutY="324.0" mnemonicParsing="false" onAction="#createAuction" prefHeight="31.0" prefWidth="150.0" style="-fx-background-color: #e79316;" text="AUCTION ITEM" textFill="WHITE">
         <font>
            <Font name="Trebuchet MS" size="15.0" />
         </font></Button>
      <VBox layoutX="409.0" layoutY="121.0" visible="false">
         <children>
            <TextField fx:id="authorTF" promptText="Author" />
            <TextField fx:id="genreTF" promptText="Genre" />
         </children>
      </VBox>
      <VBox layoutX="382.0" layoutY="121.0" visible="false">
         <children>
            <TextField fx:id="vehicleBrandTF" promptText="Brand" />
            <TextField fx:id="vinTF" prefHeight="26.0" prefWidth="204.0" promptText="Vehicle Identification Number (VIN)" />
            <TextField fx:id="mileageTF" promptText="Mileage" />
         </children>
      </VBox>
      <VBox layoutX="409.0" layoutY="121.0" visible="false">
         <children>
            <TextField fx:id="electronicsBrandTF" promptText="Brand" />
            <TextField fx:id="warrantyTF" promptText="Warranty" />
         </children>
      </VBox>
      <VBox layoutX="51.0" layoutY="95.0">
         <children>
            <Label prefHeight="26.0" prefWidth="62.0" text="General">
               <font>
                  <Font name="Trebuchet MS" size="15.0" />
               </font>
            </Label>
            <TextField fx:id="startingPriceTF" promptText="Starting Price" />
            <TextField fx:id="descriptionTF" prefHeight="144.0" prefWidth="150.0" promptText="Description" />
         </children>
      </VBox>
      <Label fx:id="itemTypeLabel" alignment="CENTER" layoutX="382.0" layoutY="95.0" prefHeight="26.0" prefWidth="204.0" text="Choose a Type!">
         <font>
            <Font name="Trebuchet MS" size="15.0" />
         </font>
      </Label>
      <Button fx:id="backButton" layoutX="498.0" layoutY="15.0" mnemonicParsing="false" onAction="#back" prefHeight="31.0" prefWidth="71.0" style="-fx-background-color: white;" text="Back" textFill="#e79316">
         <font>
            <Font name="Trebuchet MS" size="16.0" />
         </font></Button>
   </children>
</AnchorPane>

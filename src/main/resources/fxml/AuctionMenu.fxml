<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="560.0" prefWidth="820.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionMenuController">

    <children>
      <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#e79316" height="80.0" stroke="BLACK" strokeType="INSIDE" width="820.0" />
        <Label fx:id="titleLabel" layoutX="22.0" layoutY="20.0" prefHeight="38.0" prefWidth="480.0" text="Danh sách đấu giá" textFill="WHITE">
            <font>
                <Font name="Trebuchet MS" size="32.0" />
            </font>
        </Label>

        <VBox layoutX="22.0" layoutY="105.0" prefWidth="178.0" spacing="8.0">
            <children>
                <Button fx:id="allAuctionsButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Danh sách đấu giá" />
                <Button fx:id="createAuctionButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Tạo phiên đấu giá" />
                <Button fx:id="myBidsButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Lịch sử đặt giá" />
                <Button fx:id="myParticipatedButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Phiên đã tham gia" />
                <Button fx:id="myWonButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Phiên đã thắng" />
                <Button fx:id="myCreatedButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Phiên đã tạo" />
                <Button fx:id="paymentButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Thanh toán" />
            </children>
        </VBox>

        <Label layoutX="22.0" layoutY="390.0" text="Lọc loại:">
            <font>
                <Font size="18.0" />
            </font>
        </Label>

        <RadioButton fx:id="electronicsButton" layoutX="52.0" layoutY="425.0" mnemonicParsing="false" text="Electronics">
         <font>
            <Font name="Trebuchet MS" size="12.0" />
         </font></RadioButton>
        <RadioButton fx:id="artButton" layoutX="52.0" layoutY="455.0" mnemonicParsing="false" text="Art">
         <font>
            <Font name="Trebuchet MS" size="12.0" />
         </font></RadioButton>
        <RadioButton fx:id="vehicleButton" layoutX="52.0" layoutY="485.0" mnemonicParsing="false" text="Vehicle">
         <font>
            <Font name="Trebuchet MS" size="12.0" />
         </font></RadioButton>

        <ListView fx:id="auctionListView" layoutX="230.0" layoutY="105.0" prefHeight="405.0" prefWidth="550.0" />

        <Button fx:id="refreshButton" layoutX="619.0" layoutY="24.0" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="36.0" prefWidth="92.0" style="-fx-background-color: white;" text="Refresh" textFill="#e79316">
         <font>
            <Font name="Trebuchet MS" size="17.0" />
         </font></Button>
        <Button fx:id="backButton" layoutX="720.0" layoutY="24.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="36.0" prefWidth="75.0" style="-fx-background-color: white;" text="Back" textFill="#e79316">
         <font>
            <Font name="Trebuchet MS" size="17.0" />
         </font></Button>
    </children>
</AnchorPane>

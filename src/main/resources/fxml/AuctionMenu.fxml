<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="560.0" prefWidth="820.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionMenuController">

    <children>
        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#e79316" height="80.0" stroke="BLACK" strokeType="INSIDE" width="820.0" />
        <Label fx:id="titleLabel" layoutX="22.0" layoutY="20.0" prefHeight="38.0" prefWidth="430.0" text="Danh sách đấu giá" textFill="WHITE">
            <font>
                <Font name="Tahoma" size="32.0" />
            </font>
        </Label>
        <Label fx:id="userInfoLabel" alignment="CENTER_RIGHT" layoutX="455.0" layoutY="12.0" prefHeight="24.0" prefWidth="150.0" textFill="WHITE">
            <font>
                <Font name="Tahoma" size="13.0" />
            </font>
        </Label>
        <Label fx:id="balanceLabel" alignment="CENTER_RIGHT" layoutX="455.0" layoutY="40.0" prefHeight="22.0" prefWidth="150.0" textFill="WHITE">
            <font>
                <Font name="Tahoma" size="12.0" />
            </font>
        </Label>

        <Button fx:id="topUpButton" layoutX="620.0" layoutY="24.0" mnemonicParsing="false" prefHeight="30.0" prefWidth="82.0" style="-fx-background-color: white;" text="Nạp tiền" textFill="#e79316">
            <font>
                <Font name="Tahoma" size="13.0" />
            </font>
        </Button>
        <Button fx:id="backButton" layoutX="710.0" layoutY="24.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="30.0" prefWidth="86.0" style="-fx-background-color: white;" text="Đăng xuất" textFill="#e79316">
            <font>
                <Font name="Tahoma" size="13.0" />
            </font>
        </Button>

        <VBox layoutX="22.0" layoutY="105.0" prefWidth="178.0" spacing="8.0">
            <children>
                <Button fx:id="allAuctionsButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Hệ thống đấu giá" />
                <Button fx:id="createAuctionButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Tạo phiên đấu giá" />
                <Button fx:id="myBidsButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Lịch sử đặt giá" />
                <Button fx:id="myParticipatedButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Phiên đã tham gia" />
                <Button fx:id="myWonButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Phiên đã thắng" />
                <Button fx:id="myCreatedButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Phiên đã tạo" />
                <Button fx:id="paymentButton" mnemonicParsing="false" prefHeight="32.0" prefWidth="178.0" text="Thanh toán" />
            </children>
        </VBox>

        <HBox fx:id="statusFilterBar" layoutX="230.0" layoutY="105.0" prefHeight="36.0" prefWidth="450.0" spacing="8.0">
            <children>
                <ToggleButton fx:id="allAuctionsToggle" mnemonicParsing="false" prefHeight="32.0" prefWidth="96.0" text="Tất cả" />
                <ToggleButton fx:id="openAuctionsToggle" mnemonicParsing="false" prefHeight="32.0" prefWidth="108.0" text="Sắp diễn ra" />
                <ToggleButton fx:id="runningAuctionsToggle" mnemonicParsing="false" prefHeight="32.0" prefWidth="112.0" text="Đang diễn ra" />
                <ToggleButton fx:id="finishedAuctionsToggle" mnemonicParsing="false" prefHeight="32.0" prefWidth="112.0" text="Đã kết thúc" />
            </children>
        </HBox>

        <Button fx:id="refreshButton" layoutX="690.0" layoutY="105.0" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #e79316;" text="Refresh" textFill="WHITE">
            <font>
                <Font name="Tahoma" size="14.0" />
            </font>
        </Button>

        <ListView fx:id="auctionListView" layoutX="230.0" layoutY="150.0" prefHeight="360.0" prefWidth="550.0" />
    </children>
</AnchorPane>

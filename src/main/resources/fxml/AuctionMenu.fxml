<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionMenuController">

    <children>
      <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#e79316" height="80.0" stroke="BLACK" strokeType="INSIDE" width="700.0" />
        <Label layoutX="22.0" layoutY="20.0" prefHeight="30.0" prefWidth="285.0" text="AUCTION LIST" textFill="WHITE">
            <font>
                <Font name="Trebuchet MS" size="37.0" />
            </font>
        </Label>

        <Label layoutX="22.0" layoutY="110.0" text="Sort by:">
            <font>
                <Font size="18.0" />
            </font>
        </Label>

        <RadioButton fx:id="electronicsButton" layoutX="52.0" layoutY="149.0" mnemonicParsing="false" text="Electronics">
         <font>
            <Font name="Trebuchet MS" size="12.0" />
         </font></RadioButton>
        <RadioButton fx:id="artButton" layoutX="52.0" layoutY="179.0" mnemonicParsing="false" text="Art">
         <font>
            <Font name="Trebuchet MS" size="12.0" />
         </font></RadioButton>
        <RadioButton fx:id="vehicleButton" layoutX="52.0" layoutY="209.0" mnemonicParsing="false" text="Vehicle">
         <font>
            <Font name="Trebuchet MS" size="12.0" />
         </font></RadioButton>

        <ListView fx:id="auctionListView" layoutX="230.0" layoutY="110.0" prefHeight="330.0" prefWidth="430.0" />

        <Button fx:id="refreshButton" layoutX="61.0" layoutY="250.0" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="36.0" prefWidth="105.0" style="-fx-background-color: #e79316;" text="Refresh" textFill="WHITE">
         <font>
            <Font name="Trebuchet MS" size="17.0" />
         </font></Button>
        <Button fx:id="backButton" layoutX="568.0" layoutY="24.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="36.0" prefWidth="92.0" style="-fx-background-color: white;" text="Back" textFill="#e79316">
         <font>
            <Font name="Trebuchet MS" size="17.0" />
         </font></Button>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminAuctionMenuController">
    <children>
        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#e79316" height="80.0" stroke="BLACK" strokeType="INSIDE" width="900.0" />

        <Label layoutX="40.0" layoutY="20.0" prefHeight="40.0" prefWidth="420.0" text="ADMIN - AUCTION LIST" textFill="WHITE">
            <font>
                <Font name="Trebuchet MS" size="28.0" />
            </font>
        </Label>

        <Label layoutX="40.0" layoutY="100.0" text="Sort by:">
            <font>
                <Font size="18.0" />
            </font>
        </Label>

        <RadioButton fx:id="electronicsButton" layoutX="110.0" layoutY="140.0" mnemonicParsing="false" text="Electronics" />
        <RadioButton fx:id="artButton" layoutX="110.0" layoutY="170.0" mnemonicParsing="false" text="Art" />
        <RadioButton fx:id="vehicleButton" layoutX="110.0" layoutY="200.0" mnemonicParsing="false" text="Vehicle" />

        <ListView fx:id="auctionListView" layoutX="280.0" layoutY="125.0" prefHeight="320.0" prefWidth="570.0" />

        <Button fx:id="refreshButton" layoutX="110.0" layoutY="245.0" mnemonicParsing="false" prefHeight="36.0" prefWidth="150.0" style="-fx-background-color: #e79316;" text="Refresh" textFill="WHITE" />

        <Button fx:id="backButton" layoutX="40.0" layoutY="430.0" mnemonicParsing="false" prefHeight="36.0" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #e79316;" text="Back" textFill="#e79316" />
    </children>
</AnchorPane>


<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">
   <center>
      <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="396.0" prefWidth="640.0">
         <children>
            <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#0B5394" height="185.0" layoutX="24.0" layoutY="126.0" stroke="BLACK" strokeType="INSIDE" width="263.0" />
            <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#0B5394" height="66.0" layoutX="-4.0" stroke="BLACK" strokeType="INSIDE" width="647.0" />
            <ImageView fitHeight="262.0" fitWidth="234.0" layoutX="369.0" layoutY="94.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../picture/background.png" />
               </image>
            </ImageView>
            <Button fx:id="loginButton" layoutX="72.0" layoutY="262.0" mnemonicParsing="false" onAction="#login" prefHeight="30.0" prefWidth="168.0" style="-fx-background-color: white;" text="Login" textFill="#0B5394">
               <font>
                  <Font name="Tahoma" size="15.0" />
               </font>
            </Button>
            <Label layoutX="47.0" layoutY="155.0" text="Email" textFill="#1e1d1d">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <TextField fx:id="emailTextField" layoutX="104.0" layoutY="152.0" prefHeight="26.0" prefWidth="160.0" promptText="ex: nguyen123@gmail.com" />
            <TextField fx:id="visiblePasswordField" layoutX="104.0" layoutY="186.0" prefHeight="26.0" prefWidth="160.0" promptText="input password" />
            <Label layoutX="34.0" layoutY="189.0" text="Password" textFill="#181818">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <CheckBox fx:id="showPasswordCheckBox" layoutX="104.0" layoutY="224.0" mnemonicParsing="false" onAction="#togglePasswordVisibility" text="Show" />
            <PasswordField fx:id="hiddenPasswordField" layoutX="104.0" layoutY="186.0" prefHeight="26.0" prefWidth="160.0" promptText="input password" />
            <Label layoutX="30.0" layoutY="12.0" text="Online Auction" textFill="WHITE">
               <font>
                  <Font name="Tahoma Bold" size="36.0" />
               </font>
            </Label>
            <HBox layoutX="36.0" layoutY="323.0">
               <children>
                  <Label prefHeight="26.0" prefWidth="154.0" text="Don't have an account?">
                     <font>
                        <Font name="Tahoma Bold" size="12.0" />
                     </font>
                  </Label>
                  <Button mnemonicParsing="false" onAction="#createAccount" prefHeight="26.0" prefWidth="86.0" style="-fx-background-color: white; -fx-border-width: 1; -fx-border-style: solid;" text="Sign Up" textFill="#b47800">
                     <font>
                        <Font name="Tahoma" size="14.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
            <Label layoutX="113.0" layoutY="78.0" prefHeight="34.0" prefWidth="102.0" text="Sign In" textFill="#0B5394">
               <font>
                  <Font name="Tahoma Bold" size="27.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
   </center>
</BorderPane>

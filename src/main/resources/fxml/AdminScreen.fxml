<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminMenuController">


    <left>
        <VBox prefWidth="270.0" style="-fx-background-color: white; -fx-border-color: #e7e7e7; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="14" left="14" right="14" top="18" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10" VBox.vgrow="NEVER">
                <StackPane prefHeight="38" prefWidth="38" style="-fx-background-color: rgba(11,83,148,0.10); -fx-background-radius: 10;">
                    <Text style="-fx-font-size: 24px; -fx-fill: #0B5394; -fx-font-weight: bold;" text="+" />
                </StackPane>
                <VBox>
                    <Label style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #0B5394;" text="AUCTION" />
                    <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #2d2d2d;" text="SYSTEM" />
                </VBox>
            </HBox>

            <Label style="-fx-padding: 18 0 6 0; -fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #6b7280;" text="QUẢN LÝ ĐẤU GIÁ" />
            <Button fx:id="auctionAllSessionsButton" maxWidth="Infinity" onAction="#refresh" style="-fx-background-color: rgba(59,130,246,0.12); -fx-text-fill: #2b6cb0; -fx-font-weight: 800; -fx-background-radius: 12; -fx-padding: 10 12; -fx-alignment: CENTER_LEFT;" text="Tất cả phiên đấu giá" />
            <Button maxWidth="Infinity" onAction="#viewCanceledAuctions" style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-font-weight: 600; -fx-background-radius: 12; -fx-padding: 10 12; -fx-alignment: CENTER_LEFT;" text="Phiên đã hủy" />


            <Label style="-fx-padding: 18 0 6 0; -fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #6b7280;" text="QUẢN LÝ NGƯỜI DÙNG" />
            <Button maxWidth="Infinity" onAction="#viewAllUsers" style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-font-weight: 600; -fx-background-radius: 12; -fx-padding: 10 12; -fx-alignment: CENTER_LEFT;" text="Danh sách người dùng" />
            <Button maxWidth="Infinity" onAction="#viewBannedUsers" style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-font-weight: 600; -fx-background-radius: 12; -fx-padding: 10 12; -fx-alignment: CENTER_LEFT;" text="Người dùng bị ban" />

            <Label style="-fx-padding: 18 0 6 0; -fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #6b7280;" text="CÀI ĐẶT HỆ THỐNG" />
            <Button maxWidth="Infinity" onAction="#refresh" style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-font-weight: 600; -fx-background-radius: 12; -fx-padding: 10 12; -fx-alignment: CENTER_LEFT;" text="Quản lý Người dùng" />
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="76.0" spacing="20" style="-fx-background-color: #0B5394; -fx-padding: 0 24 0 24;">

            <HBox HBox.hgrow="ALWAYS">
            <children>
                    <Label fx:id="adminWelcomeLabel" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 700;" text="Admin" />
            </children></HBox>

            <HBox alignment="CENTER_RIGHT" spacing="16">
                <VBox alignment="CENTER_LEFT" />

                <StackPane>
                    <Text style="-fx-font-size: 18px; -fx-fill: white;" text="🔔" />
                    <Circle fill="#ef4444" radius="5" translateX="8" translateY="-8" />
                </StackPane>

                <Button fx:id="logoutButton" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: 800; -fx-cursor: hand;" text="Đăng xuất" />
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="14" style="-fx-background-color: #F4F6F9; -fx-padding: 24;">
            <Label style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #111827;" text="BẢNG QUẢN LÝ TẤT CẢ PHIÊN ĐẤU GIÁ">
                <VBox.margin>
                    <Insets bottom="4" />
                </VBox.margin>
            </Label>

            <StackPane style="-fx-background-color: white; -fx-background-radius: 14;">
                <TableView fx:id="auctionsTableView" prefHeight="520.0" prefWidth="980.0" style="-fx-background-color: transparent;">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="90.0" text="ID Phiên" />
                        <TableColumn fx:id="nameColumn" prefWidth="320.0" text="Tên sản phẩm" />
                        <TableColumn fx:id="currentPriceColumn" prefWidth="170.0" text="Giá hiện tại" />
                        <TableColumn fx:id="remainingTimeColumn" prefWidth="280.0" text="Thời gian" />
                        <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Trạng thái" />
                        <TableColumn fx:id="actionsColumn" prefWidth="150.0" text="Thao tác" />
                    </columns>
                </TableView>
            </StackPane>
        </VBox>
    </center>

</BorderPane>

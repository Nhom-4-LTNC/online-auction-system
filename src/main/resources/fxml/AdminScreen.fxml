<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AdminMenuController">
    <children>
        <Label layoutX="40.0" layoutY="20.0" prefHeight="40.0" prefWidth="420.0" text="ADMIN - QUẢN LÝ USER">
            <font>
                <Font size="28.0" />
            </font>
        </Label>

        <ListView fx:id="usersListView" layoutX="40.0" layoutY="80.0" prefHeight="420.0" prefWidth="520.0" />

        <Label layoutX="600.0" layoutY="110.0" text="User ID cần ban/unban:" />
        <TextField fx:id="targetUserIdTextField" layoutX="600.0" layoutY="135.0" prefWidth="240.0" />

        <Label layoutX="600.0" layoutY="190.0" text="Thời gian ban (ms):" />
        <TextField fx:id="durationMillisTextField" layoutX="600.0" layoutY="215.0" prefWidth="240.0" promptText="vd: 600000 (10 phút)" />

        <Button fx:id="banButton" layoutX="600.0" layoutY="270.0" mnemonicParsing="false" onAction="#applyBan" prefWidth="240.0" text="Ban" />
        <Button fx:id="unbanButton" layoutX="600.0" layoutY="315.0" mnemonicParsing="false" onAction="#removeBan" prefWidth="240.0" text="Unban" />

        <Button fx:id="refreshButton" layoutX="600.0" layoutY="380.0" mnemonicParsing="false" onAction="#refresh" prefWidth="240.0" text="Refresh users" />
<Button fx:id="backButton" layoutX="40.0" layoutY="525.0" mnemonicParsing="false" onAction="#back" prefWidth="160.0" text="Back" />

<!-- Lưu ý: Logout hiện do HomeController thực hiện. Admin back không logout server-session. -->
    </children>
</AnchorPane>


<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="root"
            prefHeight="700.0"
            prefWidth="900.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AuctionDetailController">

    <top>
        <HBox alignment="CENTER_LEFT"
              prefHeight="60.0"
              spacing="15.0"
              style="-fx-background-color: #f4f4f4; -fx-border-color: #dcdcdc; -fx-border-width: 0 0 1 0;"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <Button fx:id="backButton" mnemonicParsing="false" text="&lt; Back" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="auctionTitleLabel" text="Chi tiết phiên đấu giá" textAlignment="CENTER">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="statusLabel" text="Trạng thái: --" textFill="#2e7d32">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="centerStack">
            <children>
                <HBox spacing="30.0" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>

                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <StackPane prefHeight="280.0"
                                           style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-background-radius: 5;">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <children>
                                        <ImageView fx:id="itemImageView"
                                                   fitHeight="260.0"
                                                   fitWidth="450.0"
                                                   pickOnBounds="true"
                                                   preserveRatio="true" />
                                    </children>
                                </StackPane>

                                <Label fx:id="itemNameLabel" text="Tên sản phẩm">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>

                                <Label text="Mô tả sản phẩm:" textFill="#555555" />

                                <TextArea fx:id="descriptionArea"
                                          editable="false"
                                          focusTraversable="false"
                                          prefHeight="150.0"
                                          promptText="Mô tả chi tiết sản phẩm..."
                                          wrapText="true"
                                          VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <VBox prefWidth="350.0"
                              spacing="15.0"
                              style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <GridPane hgap="10.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="120.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="200.0" minWidth="10.0" prefWidth="180.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <Label text="Giá hiện tại:" GridPane.rowIndex="0">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="currentPriceLabel" text="-- VND" textFill="#d32f2f" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <font>
                                                <Font name="System Bold" size="20.0" />
                                            </font>
                                        </Label>

                                        <Label text="Giá khởi điểm:" textFill="#666666" GridPane.rowIndex="1" />
                                        <Label fx:id="startingPriceLabel" text="-- VND" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="Bước giá:" textFill="#666666" GridPane.rowIndex="2" />
                                        <Label fx:id="bidStepLabel" text="-- VND" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label text="Người bán:" textFill="#666666" GridPane.rowIndex="3" />
                                        <Label fx:id="sellerLabel" text="--" textFill="#1976d2" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>

                                        <Label text="Thời gian kết thúc:" textFill="#666666" GridPane.rowIndex="4" />
                                        <Label fx:id="endTimeLabel" text="--" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                    </children>
                                </GridPane>

                                <Separator prefWidth="200.0" />

                                <Label text="Tham gia đấu giá">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>

                                <HBox spacing="10.0">
                                    <children>
                                        <TextField fx:id="bidAmountField" promptText="Nhập số tiền..." HBox.hgrow="ALWAYS" />
                                        <Button fx:id="placeBidButton"
                                                mnemonicParsing="false"
                                                style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-font-weight: bold;"
                                                text="Đặt giá" />
                                    </children>
                                </HBox>

                                <Label fx:id="messageLabel" textFill="#d32f2f" wrapText="true" />

                                <Region VBox.vgrow="ALWAYS" />

                                <Button fx:id="closeAuctionButton"
                                        maxWidth="1.7976931348623157E308"
                                        mnemonicParsing="false"
                                        style="-fx-background-color: #d32f2f; -fx-text-fill: white;"
                                        text="Đóng phiên đấu giá" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Chat toggle overlay -->
                <VBox fx:id="chatOverlay"
                      visible="false"
                      managed="false"
                      alignment="TOP_RIGHT"
                      maxWidth="360.0"
                      prefWidth="360.0"
                      prefHeight="520.0"
                      style="-fx-background-color: rgba(255,255,255,0.95); -fx-border-color: #bdbdbd; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6;">
                    <children>
                        <HBox spacing="10.0" style="-fx-background-color:#f5f5f5; -fx-padding:10;" alignment="CENTER_LEFT">
                            <Label text="Chat phiên đấu giá" style="-fx-font-weight:bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="toggleChatButton" mnemonicParsing="false" text="Đóng" />
                        </HBox>

                        <VBox spacing="8.0" style="-fx-padding: 10;">
                            <TextArea fx:id="chatHistoryArea"
                                      editable="false"
                                      wrapText="true"
                                      prefHeight="360.0" />

                            <HBox spacing="8.0">
                                <TextField fx:id="chatInputField" promptText="Nhập tin nhắn..." HBox.hgrow="ALWAYS" />
                                <Button fx:id="sendChatButton" mnemonicParsing="false" text="Gửi" />
                            </HBox>
                        </VBox>
                    </children>
                </VBox>

                <Button fx:id="openChatButton"
                        mnemonicParsing="false"
                        text="Chat"
                        style="-fx-background-color:#1976D2; -fx-text-fill:white; -fx-font-weight:bold;"
                        onAction="#onToggleChat"
                        maxWidth="90.0" prefHeight="30.0" />
            </children>
        </StackPane>
    </center>


    <bottom>
        <VBox prefHeight="250.0" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="0.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label text="Lịch sử trả giá">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="refreshBidHistoryButton" mnemonicParsing="false" text="Làm mới" />
                    </children>
                </HBox>

                <TableView fx:id="bidHistoryTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="bidderColumn" prefWidth="75.0" text="Người trả giá" />
                        <TableColumn fx:id="amountColumn" prefWidth="75.0" text="Số tiền" />
                        <TableColumn fx:id="timeColumn" prefWidth="75.0" text="Thời gian" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </bottom>
</BorderPane>

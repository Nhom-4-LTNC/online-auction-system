<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="root" prefHeight="720.0" prefWidth="1180.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.AuctionDetailController">

    <top>
        <HBox alignment="CENTER_LEFT" minHeight="70.0" spacing="15.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #dcdcdc; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <Button fx:id="backButton" mnemonicParsing="false" text="&lt; Back" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="auctionTitleLabel" text="Chi tiết phiên đấu giá" textAlignment="CENTER">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="statusLabel" text="Trạng thái: --" textFill="#2e7d32">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="16.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <HBox spacing="24.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox maxWidth="Infinity" spacing="10.0" HBox.hgrow="ALWAYS">
                            <children>
                                <StackPane minHeight="260.0" style="-fx-background-color: #ffffff; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-background-radius: 5;" VBox.vgrow="ALWAYS">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <children>
                                        <ImageView fx:id="itemImageView" fitHeight="256.0" fitWidth="752.0" pickOnBounds="true" preserveRatio="true" />
                                    </children>
                                </StackPane>

                                <Label fx:id="itemNameLabel" maxWidth="Infinity" text="Tên sản phẩm" wrapText="true">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>

                                <Label text="Mô tả sản phẩm:" textFill="#555555" />

                                <TextArea fx:id="descriptionArea" editable="false" focusTraversable="false" minHeight="110.0" promptText="Mô tả chi tiết sản phẩm..." wrapText="true" />
                            </children>
                        </VBox>

                        <VBox maxHeight="Infinity" minWidth="330.0" prefWidth="380.0" spacing="15.0" style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-background-radius: 5;">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <GridPane hgap="10.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="10.0" prefWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="190.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>
                                        <Label text="Giá hiện tại:" GridPane.rowIndex="0">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="currentPriceLabel" text="-- VND" textFill="#d32f2f" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <font>
                                                <Font name="System Bold" size="20.0" />
                                            </font>
                                        </Label>

                                        <Label text="Giá khởi điểm:" textFill="#666666" GridPane.rowIndex="1" />
                                        <Label fx:id="startingPriceLabel" text="-- VND" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="Bước giá:" textFill="#666666" GridPane.rowIndex="2" />
                                        <Label fx:id="bidStepLabel" text="-- VND" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label text="Người bán:" textFill="#666666" GridPane.rowIndex="3" />
                                        <Label fx:id="sellerLabel" text="--" textFill="#1976d2" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>

                                        <Label text="Thời gian kết thúc:" textFill="#666666" GridPane.rowIndex="4" />
                                        <Label fx:id="endTimeLabel" text="--" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                        <Label text="Thời gian bắt đầu:" textFill="#666666" GridPane.rowIndex="5" />
                                        <Label fx:id="startTimeLabel" text="--" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                        <Label text="Người thắng:" textFill="#666666" GridPane.rowIndex="6" />
                                        <Label fx:id="winnerLabel" text="--" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                                        <Label text="Thời gian:" textFill="#666666" GridPane.rowIndex="7" />
                                        <Label fx:id="timeRemainingLabel" text="--" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                                    </children>
                                </GridPane>

                                <Separator />

                                <Label text="Tham gia đấu giá">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>

                                <HBox spacing="10.0">
                                    <children>
                                        <TextField fx:id="bidAmountField" promptText="Nhập số tiền..." HBox.hgrow="ALWAYS" />
                                        <Button fx:id="placeBidButton" mnemonicParsing="false" style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-font-weight: bold;" text="Đặt giá" />
                                    </children>
                                </HBox>

                                <Label fx:id="messageLabel" textFill="#d32f2f" wrapText="true" />

                                <Region VBox.vgrow="ALWAYS" />

                                <Button fx:id="updateAuctionButton" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: #1976d2; -fx-text-fill: white;" text="Sửa phiên đấu giá" />
                                <Button fx:id="cancelAuctionButton" maxWidth="Infinity" mnemonicParsing="false" style="-fx-background-color: #f57c00; -fx-text-fill: white;" text="Hủy phiên đấu giá" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox minHeight="220.0" prefHeight="260.0" spacing="10.0">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Lịch sử trả giá">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="refreshBidHistoryButton" mnemonicParsing="false" text="Làm mới" />
                            </children>
                        </HBox>

                        <TableView fx:id="bidHistoryTable" maxHeight="Infinity" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="bidderColumn" prefWidth="75.0" text="Người trả giá" />
                                <TableColumn fx:id="amountColumn" prefWidth="75.0" text="Số tiền" />
                                <TableColumn fx:id="timeColumn" prefWidth="75.0" text="Thời gian" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>

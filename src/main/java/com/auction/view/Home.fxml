<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="scenePane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.HomeController">
   <children>
      <ImageView fitHeight="400.0" fitWidth="600.0" layoutX="81.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@uet.png" />
         </image>
      </ImageView>
      <Button fx:id="signOutButton" layoutX="353.0" layoutY="24.0" mnemonicParsing="false" onAction="#SignOut" text="Sign Out" />
      <Button fx:id="signInButton" layoutX="459.0" layoutY="24.0" mnemonicParsing="false" onAction="#SignIn" text="Sign In" />
   </children>
</AnchorPane>
